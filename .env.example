# Database (default matches docker-compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ragdb

# Vector collection
COLLECTION_NAME=pdf_documents

# Optional: comma-separated request prefixes for single-field extraction (trailing space matters). Example format: "prefix1 ,prefix2 "
# FIELD_REQUEST_PREFIXES=

# Ollama (local). Embeddings still use Ollama unless you change ingest.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Groq (free API). Set GROQ_API_KEY to use ChatGroq for RAG instead of Ollama (instant responses).
# Get key at https://console.groq.com
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant

# Chunking (RecursiveCharacterTextSplitter: 1000 / 100)
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
TOP_K_RETRIEVAL=5
AGENT_RECURSION_LIMIT=6
RETRIEVAL_WINDOW_SIZE=2

# ParentDocumentRetriever: search small chunks, return full parent context
USE_PARENT_DOCUMENT_RETRIEVER=true
CHILD_CHUNK_SIZE=300
CHILD_CHUNK_OVERLAP=50

# Extraction speed: smaller context and token limit = faster LLM response (tune via env only)
EXTRACTOR_MAX_CONTEXT_CHARS=5000
EXTRACTOR_NUM_PREDICT=120
# Optional: use a smaller/faster model for extraction only (e.g. llama3.2:1b)
# OLLAMA_EXTRACTOR_MODEL=

# Section extraction fast path: max lines under a heading (no LLM)
SECTION_EXTRACT_MAX_LINES=50
